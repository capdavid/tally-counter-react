{
    "name": "Tally counter",
    "version": "1.3.1",
    "description": "Easy & intuitive tally counter for keeping track of anything you want.",
    "manifest_version": 3,
    "permissions": ["declarativeContent", "notifications", "storage"],
    "background": {
        "service_worker": "background.js",
        "type": "module"
    },
    "action": {
        "default_icon": {
            "16": "images/icon16.png",
            "48": "images/icon48.png",
            "128": "images/icon48.png"
        },
        "default_popup": "index.html"
    },
    "icons": {
        "16": "images/icon16.png",
        "48": "images/icon48.png",
        "128": "images/icon48.png"
    },
    "commands": {
        "00inc": {
            "suggested_key": {
                "default": "Alt+1",
                "mac": "MacCtrl+1"
            },
            "description": "First item +1"
        },
        "01inc": {
            "description": "Second item +1"
        },
        "02inc": {
            "description": "Third item +1"
        },
        "03inc": {
            "description": "Fourth item +1"
        },
        "04inc": {
            "description": "Fifth item +1"
        },
        "05inc": {
            "description": "Sixth item +1"
        },
        "06inc": {
            "description": "Seventh item +1"
        },
        "07inc": {
            "description": "Eighth item +1"
        },
        "08inc": {
            "description": "Ninth item +1"
        },
        "09inc": {
            "description": "Tenth item +1"
        },
        "10inc": {
            "description": "Eleventh item +1"
        },
        "11inc": {
            "description": "Twelfth item +1"
        },
        "00zdec": {
            "suggested_key": {
                "default": "Alt+Shift+1",
                "mac": "MacCtrl+Shift+1"
            },
            "description": "First item -1"
        },
        "01zdec": {
            "description": "Second item -1"
        },
        "02zdec": {
            "description": "Third item -1"
        },
        "03zdec": {
            "description": "Fourth item -1"
        },
        "04zdec": {
            "description": "Fifth item -1"
        },
        "05zdec": {
            "description": "Sixth item -1"
        },
        "06zdec": {
            "description": "Seventh item -1"
        },
        "07zdec": {
            "description": "Eighth item -1"
        },
        "08zdec": {
            "description": "Ninth item -1"
        },
        "09zdec": {
            "description": "Tenth item -1"
        },
        "10zdec": {
            "description": "Eleventh item -1"
        },
        "11zdec": {
            "description": "Twelfth item -1"
        },
        "_execute_action": {
            "suggested_key": {
                "default": "Alt+T",
                "mac": "MacCtrl+T"
            }
        }
    }
}
